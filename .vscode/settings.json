{
  "python.analysis.typeCheckingMode": "basic",
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "editor.formatOnSave": true,
  "mypy.runUsingActiveInterpreter": true,
  "python.testing.unittestArgs": [
    "-v",
    "-s",
    "./unit_test",
    "-p",
    "test*.py",
    "--cov=omotes_simulator_core",
    "--cov-report html",
    "--cov-report term-missing",
    "--cov-fail-under 80"
  ],
  "python.testing.pytestEnabled": false,
  "python.testing.unittestEnabled": true,
  "chat.tools.terminal.autoApprove": {
    "doc\\make.bat": true,
    ".\\doc\\make.bat": true,
    "/^cmd /c \"c:\\\\repositories\\\\NWN\\\\simulator-core\\\\doc\\\\make\\.bat html\"$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^& \\.\\\\doc\\\\run_spinx\\.bat$/": {
      "approve": true,
      "matchCommandLine": true
    },
    "/^doc\\\\venv\\\\Scripts\\\\sphinx-build -b html doc doc\\\\_build\\\\html$/": {
      "approve": true,
      "matchCommandLine": true
    },
    ".\\doc\\run_spinx.bat": true,
    "/^& \\.\\\\venv\\\\Scripts\\\\python\\.exe -m sphinx -b html doc doc\\\\_build\\\\html$/": {
      "approve": true,
      "matchCommandLine": true
    }
  },
}
